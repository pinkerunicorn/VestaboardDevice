{
    "elements": [
        { "type": "Label", "label": "Variablen-Zuordnung für das Vestaboard" },
        { 
            "type": "List", 
            "name": "VariablesList", 
            "caption": "Variablen Zuordnung",
            "add": true,
            "delete": true,
            "columns": [
                {
                    "name": "Priority",
                    "caption": "Prio",
                    "type": "Select",
                    "options": [
                        { "label": "Hoch", "value": "high" },
                        { "label": "Niedrig", "value": "low" }
                    ],
                    "width": "100px",
                    "add": "low",
                    "edit": {
                        "type": "Select",
                        "options": [
                            { "label": "Hoch", "value": "high" },
                            { "label": "Niedrig", "value": "low" }
                        ]
                    }
                },
                {
                    "name": "Active",
                    "caption": "Aktiv",
                    "type": "CheckBox",
                    "width": "80px",
                    "add": true,
                    "edit": { "type": "CheckBox" }
                },
                {
                    "name": "Type",
                    "caption": "Typ",
                    "type": "Select",
                    "options": [
                        { "label": "Fortschrittsbalken", "value": "wm" },
                        { "label": "Briefkasten", "value": "brief" },
                        { "label": "Müllabfuhr", "value": "muell" },
                        { "label": "Keller Lüften", "value": "keller" },
                        { "label": "Ofen", "value": "ofen" },
                        { "label": "S-Bahn", "value": "sbahn" },
                        { "label": "Temperatur", "value": "aussen" },
                        { "label": "Gartenbewässerung", "value": "garten" },
                        { "label": "Offene Fenster/Türen", "value": "fenster" },
                        { "label": "Benutzerdefiniert (Text)", "value": "custom" }
                    ],
                    "width": "200px",
                    "add": "wm",
                    "edit": {
                        "type": "Select",
                        "options": [
                            { "label": "Fortschrittsbalken", "value": "wm" },
                            { "label": "Briefkasten", "value": "brief" },
                            { "label": "Müllabfuhr", "value": "muell" },
                            { "label": "Keller Lüften", "value": "keller" },
                            { "label": "Ofen", "value": "ofen" },
                            { "label": "S-Bahn", "value": "sbahn" },
                            { "label": "Temperatur", "value": "aussen" },
                            { "label": "Gartenbewässerung", "value": "garten" },
                            { "label": "Offene Fenster/Türen", "value": "fenster" },
                            { "label": "Benutzerdefiniert (Text)", "value": "custom" }
                        ]
                    }
                },
                {
                    "name": "VariableID",
                    "caption": "Variable",
                    "type": "SelectVariable",
                    "width": "auto",
                    "add": 0,
                    "edit": { "type": "SelectVariable" }
                },
                {
                    "name": "FormatString",
                    "caption": "Format / Prefix (für 'Benutzerdefiniert')",
                    "type": "ValidationTextBox",
                    "width": "300px",
                    "add": "",
                    "edit": { "type": "ValidationTextBox" }
                }
            ]
        },
        { "type": "Label", "label": "Ausgabe" },
        { "type": "SelectInstance", "name": "InstIdVestaboardLocal", "caption": "Vestaboard Local Instanz" }
    ],
    "actions": [
        { "type": "Button", "label": "Board jetzt manuell aktualisieren", "onClick": "VESTA_UpdateBoard($id);" }
    ]
}
